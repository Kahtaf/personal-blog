---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime, cleanSlug } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";
import BlogPhotoSwipe from "@components/BlogPhotoSwipe.astro";
import { SITE } from "@consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: cleanSlug(post.id) },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await render(post);
const isDev = import.meta.env.DEV;
---

<PageLayout title={post.data.title} description={post.data.description} type="article" publishDate={post.data.date} author={SITE.NAME}>
  <Container>
    <div class="animate">
      <BackToPrev href="/blog">
        Back to blog
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body ?? "")}
        </div>
      </div>
      <h1 class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </h1>
    </div>
    <article class="animate" data-blog-content>
      <Content />
    </article>
    <BlogPhotoSwipe />
    {isDev && (
      <>
        <style is:inline>
          mark[data-air-id] {
            background-color: transparent !important;
            border-radius: 0 !important;
            box-shadow: inset 0 -1px rgba(217, 119, 6, 0.75);
          }

          .blog-mobile-review {
            position: fixed;
            left: 50%;
            bottom: max(1rem, env(safe-area-inset-bottom));
            z-index: 10004;
            display: none;
            width: min(calc(100vw - 2rem), 28rem);
            transform: translateX(-50%);
            border: 1px solid rgba(255, 255, 255, 0.16);
            border-radius: 0.9rem;
            background: rgba(24, 24, 27, 0.96);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
            color: white;
            padding: 0.85rem;
          }

          @media (pointer: coarse) and (max-width: 768px) {
            .blog-mobile-review[data-visible="true"] {
              display: block;
            }
          }

          .blog-mobile-review__selected {
            max-height: 3.2rem;
            overflow: hidden;
            color: #fcd34d;
            font-size: 0.78rem;
            font-style: italic;
            line-height: 1.35;
            margin-bottom: 0.55rem;
          }

          .blog-mobile-review__textarea {
            width: 100%;
            min-height: 5rem;
            resize: vertical;
            border: 1px solid rgba(255, 255, 255, 0.18);
            border-radius: 0.55rem;
            background: rgba(39, 39, 42, 0.98);
            color: white;
            font: inherit;
            font-size: 0.9rem;
            padding: 0.6rem;
          }

          .blog-mobile-review__actions {
            display: flex;
            justify-content: flex-end;
            gap: 0.5rem;
            margin-top: 0.6rem;
          }

          .blog-mobile-review__button {
            border: 0;
            border-radius: 0.5rem;
            padding: 0.5rem 0.8rem;
            font: inherit;
            font-size: 0.85rem;
          }

          .blog-mobile-review__button--cancel {
            background: #3f3f46;
            color: #e4e4e7;
          }

          .blog-mobile-review__button--save {
            background: #d97706;
            color: white;
          }
        </style>
        <div class="blog-mobile-review" data-blog-mobile-review aria-live="polite">
          <div class="blog-mobile-review__selected" data-blog-mobile-review-selected></div>
          <textarea
            class="blog-mobile-review__textarea"
            data-blog-mobile-review-note
            placeholder="Comment for the agent..."
          ></textarea>
          <div class="blog-mobile-review__actions">
            <button class="blog-mobile-review__button blog-mobile-review__button--cancel" type="button" data-blog-mobile-review-cancel>
              Cancel
            </button>
            <button class="blog-mobile-review__button blog-mobile-review__button--save" type="button" data-blog-mobile-review-save>
              Save comment
            </button>
          </div>
        </div>
        <script is:inline>
          (() => {
            const article = document.querySelector("article");
            const reviewBox = document.querySelector("[data-blog-mobile-review]");
            const selectedEl = document.querySelector("[data-blog-mobile-review-selected]");
            const noteEl = document.querySelector("[data-blog-mobile-review-note]");
            const cancelEl = document.querySelector("[data-blog-mobile-review-cancel]");
            const saveEl = document.querySelector("[data-blog-mobile-review-save]");
            if (!article || !reviewBox || !selectedEl || !noteEl || !cancelEl || !saveEl) return;

            const contextLength = 80;
            const isMobileReviewDevice = window.matchMedia("(pointer: coarse) and (max-width: 768px)").matches;
            let savedRange = null;

            function getXPath(node) {
              if (node.nodeType === Node.TEXT_NODE) {
                const parent = node.parentNode;
                if (!parent) return "";
                let textIndex = 0;
                for (const child of Array.from(parent.childNodes)) {
                  if (child.nodeType === Node.TEXT_NODE) textIndex++;
                  if (child === node) break;
                }
                return `${getXPath(parent)}/text()[${textIndex}]`;
              }
              if (node.nodeType !== Node.ELEMENT_NODE) return "";
              const element = node;
              if (element === document.documentElement) return "/html[1]";
              const parent = element.parentNode;
              if (!parent) return `/${element.tagName.toLowerCase()}[1]`;
              let index = 0;
              for (const child of Array.from(parent.childNodes)) {
                if (child.nodeType === Node.ELEMENT_NODE && child.tagName === element.tagName) index++;
                if (child === element) break;
              }
              const parentPath = parent === document ? "" : getXPath(parent);
              return `${parentPath}/${element.tagName.toLowerCase()}[${index}]`;
            }

            function getTextNodes(root) {
              const nodes = [];
              const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
              let node;
              while ((node = walker.nextNode())) nodes.push(node);
              return nodes;
            }

            function getBlockAncestor(node) {
              const blockTags = new Set(["ARTICLE", "BLOCKQUOTE", "DIV", "H1", "H2", "H3", "H4", "LI", "P", "PRE", "SECTION", "UL", "OL"]);
              let current = node.nodeType === Node.ELEMENT_NODE ? node : node.parentElement;
              while (current && current !== document.body) {
                if (blockTags.has(current.tagName)) return current;
                current = current.parentElement;
              }
              return article;
            }

            function extractContextBefore(range) {
              const block = getBlockAncestor(range.startContainer);
              const nodes = getTextNodes(block);
              let fullText = "";
              let start = -1;
              for (const node of nodes) {
                if (node === range.startContainer) start = fullText.length + range.startOffset;
                fullText += node.textContent || "";
              }
              if (start < 0) return "";
              return fullText.slice(Math.max(0, start - contextLength), start);
            }

            function extractContextAfter(range) {
              const block = getBlockAncestor(range.endContainer);
              const nodes = getTextNodes(block);
              let fullText = "";
              let end = -1;
              for (const node of nodes) {
                if (node === range.endContainer) end = fullText.length + range.endOffset;
                fullText += node.textContent || "";
              }
              if (end < 0) return "";
              return fullText.slice(end, Math.min(fullText.length, end + contextLength));
            }

            function serializeRange(range) {
              return {
                startXPath: getXPath(range.startContainer),
                startOffset: range.startOffset,
                endXPath: getXPath(range.endContainer),
                endOffset: range.endOffset,
                selectedText: range.toString(),
                contextBefore: extractContextBefore(range),
                contextAfter: extractContextAfter(range),
              };
            }

            function updateSelection() {
              if (!isMobileReviewDevice) return;
              const selection = window.getSelection();
              if (!selection || selection.isCollapsed || !selection.rangeCount) return;
              const range = selection.getRangeAt(0);
              const text = range.toString().trim();
              if (!text || text.length < 2) return;
              if (!article.contains(range.commonAncestorContainer)) return;
              savedRange = range.cloneRange();
              selectedEl.textContent = `“${text.length > 180 ? `${text.slice(0, 180)}…` : text}”`;
              reviewBox.setAttribute("data-visible", "true");
            }

            function hideBox(clearSelection = false) {
              reviewBox.removeAttribute("data-visible");
              noteEl.value = "";
              savedRange = null;
              if (clearSelection) window.getSelection()?.removeAllRanges();
            }

            document.addEventListener("selectionchange", () => {
              window.setTimeout(updateSelection, 80);
            });
            document.addEventListener("touchend", () => {
              window.setTimeout(updateSelection, 250);
            }, { passive: true });

            cancelEl.addEventListener("click", () => hideBox(true));
            saveEl.addEventListener("click", async () => {
              if (!savedRange) return;
              const note = noteEl.value.trim();
              if (!note) {
                noteEl.focus();
                return;
              }
              const selectedText = savedRange.toString();
              saveEl.setAttribute("disabled", "true");
              try {
                await fetch("/__inline-review/api/annotations", {
                  method: "POST",
                  headers: { "content-type": "application/json" },
                  body: JSON.stringify({
                    type: "text",
                    pageUrl: window.location.pathname,
                    pageTitle: document.title,
                    selectedText,
                    note,
                    range: serializeRange(savedRange),
                  }),
                }).then((response) => {
                  if (!response.ok) throw new Error(`HTTP ${response.status}`);
                });
                hideBox(true);
              } catch (error) {
                selectedEl.textContent = error instanceof Error ? error.message : String(error);
              } finally {
                saveEl.removeAttribute("disabled");
              }
            });
          })();
        </script>
      </>
    )}
  </Container>
</PageLayout>
