---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { RESUME } from "@consts";

const entries = await getCollection("resume");
const entry = entries[0];
const { Content } = await entry.render();
---

<PageLayout title={RESUME.TITLE} description={RESUME.DESCRIPTION}>
  <Container>
    <div class="relative">
      <button
        onclick="window.print()"
        class="no-print absolute right-0 top-0 text-sm border border-black/15 dark:border-white/25 px-3 py-1 rounded hover:bg-black/5 dark:hover:bg-white/10 transition-colors text-current cursor-pointer"
      >
        PDF
      </button>
      <article class="resume-content">
        <Content />
      </article>
    </div>
  </Container>
</PageLayout>

<style is:global>
  .resume-header h1 {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: black;
  }

  html.dark .resume-header h1 {
    color: white;
  }

  .resume-header p {
    font-size: 0.875rem;
    line-height: 1.25rem;
  }

  .resume-header p:first-of-type {
    color: rgb(0 0 0 / 0.75);
  }

  .resume-header p:last-of-type {
    color: rgb(0 0 0 / 0.5);
  }

  html.dark .resume-header p:first-of-type {
    color: rgb(255 255 255 / 0.75);
  }

  html.dark .resume-header p:last-of-type {
    color: rgb(255 255 255 / 0.5);
  }

  .resume-entry {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 1.5rem;
  }

  .resume-entry strong {
    font-weight: 600;
    color: black;
  }

  html.dark .resume-entry strong {
    color: white;
  }

  .resume-entry span {
    font-size: 0.875rem;
    line-height: 1.25rem;
    white-space: nowrap;
    margin-left: 1rem;
    flex-shrink: 0;
  }

  @media print {
    header,
    footer,
    .no-print {
      display: none !important;
    }

    html, html.dark {
      color-scheme: light;
    }

    body, html.dark body {
      background: white !important;
      color: black !important;
      display: block;
    }

    main {
      padding: 0 !important;
    }

    .animate {
      opacity: 1 !important;
      transform: none !important;
    }

    main > div {
      max-width: none !important;
    }

    .resume-content {
      color: black !important;
      font-size: 11pt;
      line-height: 1.4;
    }

    .resume-content h2 {
      color: black !important;
      font-size: 13pt;
      margin-top: 12pt;
      margin-bottom: 4pt;
    }

    .resume-content ul {
      margin-top: 2pt;
      margin-bottom: 2pt;
    }

    .resume-content li {
      margin-top: 0;
      margin-bottom: 1pt;
    }

    .resume-content strong {
      color: black !important;
    }

    .resume-content a {
      color: black !important;
      text-decoration: none !important;
    }

    .resume-header a {
      color: black !important;
      text-decoration: none !important;
    }

    .resume-header h1 {
      color: black !important;
    }

    .resume-header p {
      color: black !important;
    }

    .resume-content hr {
      border-color: #ccc;
    }

    h2, h3 {
      break-after: avoid;
    }

    li, .resume-entry {
      break-inside: avoid;
    }

    @page {
      margin: 0.5in 0.6in;
      size: letter;
    }
  }
</style>
