---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface GalleryImage {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  images: GalleryImage[];
  label: string;
}

const { images, label } = Astro.props;
---

<figure class="blog-image-lightbox blog-image-gallery" data-blog-lightbox-gallery aria-label={label}>
  <div class="blog-image-gallery__track">
    {
      images.map((image, index) => {
        const src = typeof image.src === "string" ? image.src : image.src.src;
        const width = typeof image.src === "string" ? undefined : image.src.width;
        const height = typeof image.src === "string" ? undefined : image.src.height;
        const caption = image.caption;
        const accessibleLabel = caption ?? image.alt;

        return (
          <a
            class="blog-image-gallery__item"
            href={src}
            data-blog-lightbox-image
            data-blog-lightbox-caption={caption}
            data-pswp-src={src}
            data-pswp-width={width}
            data-pswp-height={height}
            aria-label={`Open image ${index + 1} of ${images.length}: ${accessibleLabel}`}
          >
            <Image src={image.src} alt={image.alt} loading="lazy" decoding="async" />
            {caption && <span class="blog-image-gallery__caption">{caption}</span>}
          </a>
        );
      })
    }
  </div>
  <figcaption>{label}</figcaption>
</figure>
