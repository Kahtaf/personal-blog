---
import "photoswipe/style.css";
---

<script>
  import "../scripts/blog-photoswipe";
</script>

<style is:global>
  article [data-blog-lightbox-image] {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  article .blog-image-lightbox {
    margin-block: 2.25rem;
  }

  article .blog-image-lightbox img {
    width: 100%;
    height: auto;
    border: 1px solid rgb(0 0 0 / 0.08);
    border-radius: 0.5rem;
    background: rgb(255 255 255 / 0.55);
  }

  html.dark article .blog-image-lightbox img {
    border-color: rgb(255 255 255 / 0.12);
    background: rgb(255 255 255 / 0.04);
  }

  article .blog-image-lightbox figcaption {
    margin-top: 0.65rem;
    color: rgb(0 0 0 / 0.48);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    text-align: center;
  }

  html.dark article .blog-image-lightbox figcaption {
    color: rgb(255 255 255 / 0.58);
  }

  .pswp__blog-caption {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    left: 1rem;
    z-index: 1;
    margin-inline: auto;
    max-width: min(42rem, calc(100vw - 2rem));
    color: rgb(255 255 255 / 0.86);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.5;
    text-align: center;
    text-shadow: 0 1px 2px rgb(0 0 0 / 0.8);
  }

  .pswp__blog-caption:empty {
    display: none;
  }
</style>
