---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";

const hasProjects = (await getCollection("projects")).some((p) => !p.data.draft);
---

<header>
  <Container>
    <div class="flex flex-wrap gap-y-2 justify-between">
      <Link href="/" underline={false}>
        <div class="group font-semibold flex items-center gap-2">
          <img src="/k-logo.svg" alt="" class="h-5 w-5 opacity-50 group-hover:opacity-100 dark:invert dark:opacity-75 dark:group-hover:opacity-100 transition-opacity duration-300 ease-in-out" />
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex gap-1">
        <Link href="/about"> about </Link>
        <span>
          {`/`}
        </span>
        <Link href="/blog"> blog </Link>
        <span>
          {`/`}
        </span>
        <Link href="/work"> work </Link>
        {hasProjects && (
          <>
            <span>{`/`}</span>
            <Link href="/projects"> projects </Link>
          </>
        )}
      </nav>
    </div>
  </Container>
</header>
